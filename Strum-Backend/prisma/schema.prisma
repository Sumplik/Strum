// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Device {
  id        String      @id // device_id
  status    String      @default("off") // off, idle, on_duty (diekstrak untuk indexing/stats cepat)
  lastSeen  DateTime    @default(now())
  rawData   Json        // Menyimpan raw json payload terakhir
  
  // Field-field tambahan untuk frontend
  ipAddress     String?
  voltase       Float?
  arus          Float?
  suhu          Float?
  kelembapan    Float?
  thresholdIdle Float?
  thresholdDuty Float?
  location      String?   // Lokasi/workshop (W1, W2, W3, W4, W5, G1)
  
  logs      DeviceLog[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model DeviceLog {
  id        String   @id @default(uuid())
  deviceId  String
  device    Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  timestamp DateTime
  rawData   Json     // Raw json payload saat itu
  createdAt DateTime @default(now())

  status    String   // off, idle, on_duty
  @@index([deviceId, timestamp]) // Penting untuk query kalkulasi durasi/summary
  @@index([timestamp])
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String // Disimpan dalam bentuk hash (bcrypt/argon2)
}

model AppConfig {
  key   String @id // "operational_hours"
  value Json   // {"start": "08:00", "end": "17:00"}
}